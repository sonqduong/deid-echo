FORMAT dicom

%filter test

LABEL Son Duong Start with 0s
  present SequenceOfUltrasoundRegions
  coordinates all

# If ultrasound regions exist, keep exactly those regions (dont mask them)
LABEL Keep Ultrasound Regions
  present SequenceOfUltrasoundRegions
  keepcoordinates from:SequenceOfUltrasoundRegions

